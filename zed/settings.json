{
  "ui_font_family": "Iosevka Nerd Font Mono",
  "autosave": "on_focus_change",
  "buffer_font_family": "Iosevka Nerd Font Mono",
  "icon_theme": "Zed (Default)",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "dark",
    "light": "Rosé Pine Dawn",
    "dark": "Kanagawa",
  },
  "languages": {
    "Starlark": {
      "formatter": {
        "external": {
          "command": "buildifier",
          "arguments": ["-path", "{buffer_path}"],
        },
      },
    },
  },
  "title_bar": {
    "show_onboarding_banner": false,
    "show_project_items": false,
    "show_branch_name": true,
    "show_user_menu": false,
    "show_user_picture": false,
    "show_sign_in": false,
  },
  "tab_bar": {
    "show": false,
  },
  "toolbar": {
    "quick_actions": false,
  },
  "project_panel": {
    "default_width": 350,
    "hide_root": true,
    "auto_fold_dirs": false,
    "sticky_scroll": false,
    "scrollbar": {
      "show": "never",
    },
  },
}
